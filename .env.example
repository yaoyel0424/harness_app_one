# 应用配置（复制为 .env 后修改）
# cp .env.example .env
APP_NAME=myapp
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# 开发服务器（poetry run myapp）；Docker 生产镜像用 gunicorn 绑定 0.0.0.0
# HOST=127.0.0.1
# PORT=8000

# 可选：写入 JSONL 供 Promtail/Loki 采集（需挂载 logs/ 目录）
# LOG_FILE=logs/myapp.jsonl

# 数据库（asyncpg 驱动；Docker 映射端口 5433，避免与本机 PostgreSQL 5432 冲突）
DATABASE_URL=postgresql+asyncpg://myapp:myapp@127.0.0.1:5433/myapp

# OpenTelemetry（需启动 docker-compose.observability.yml 中的 Tempo）
OTEL_ENABLED=false
OTEL_SERVICE_NAME=myapp
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ---------------------------------------------------------------------------
# 自动运维 / 可观测性栈（docker compose -f docker-compose.observability.yml --env-file .env）
# 获取 GITHUB_TOKEN: GitHub → Settings → Developer settings → Personal access tokens
# 权限建议: repo + workflow（或 Fine-grained: Contents/Actions/Pull requests 读写）
# ---------------------------------------------------------------------------

# oncall-relay 转发告警到 GitHub Actions（走 GHA 路径时必填；仅 Cursor Automation 可不填）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-org/harness
ONCALL_WEBHOOK_SECRET=change-me-to-random-string

# relay 熔断与冷却
ONCALL_ENABLED=true
ONCALL_COOLDOWN_SEC=3600

# 可选: Cursor Automation Webhook（保存 Automation 后复制 URL 与 Bearer token）
# CURSOR_AUTOMATION_WEBHOOK_URL=https://api2.cursor.sh/automations/webhook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CURSOR_AUTOMATION_WEBHOOK_SECRET=crsr_xxxxxxxx（不含 "Bearer " 前缀，relay 会自动加）

# GitHub Actions 仓库配置（在 GitHub 网页 Settings → Secrets and variables → Actions 填写，非 .env）
# Secrets:  ONCALL_WEBHOOK_SECRET（与上方一致）、CURSOR_API_KEY（仅 GHA+SDK 路径）
# Variables: AUTO_FIX_ENABLED=true、AUTO_MERGE_ENABLED=false
